# Hub API (browser/plugin → hub)
WEVIBE_HUB_URL=http://localhost:4440
# Chain REST trust anchor used for org endpoint resolution
WEVIBE_CHAIN_REST_URL=http://localhost:1317
# Dashboard base URL used for the plugin→dashboard pairing/adopt deep link
WEVIBE_DASHBOARD_URL=https://app.wevibe.network
# Ollama (LLM + embeddings)
WEVIBE_OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
# Local moderation dashboard server
WEVIBE_DASHBOARD_PORT=4451
WEVIBE_HTTP_HOST=127.0.0.1
# Models
WEVIBE_EMBEDDING_MODEL=nomic-embed-text
