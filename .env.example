# ── WeVibe MCP environment ────────────────────────────────────────────────
# ONE flag switches every service between localhost and the public hosts:
#   WEVIBE_ENV=local        → all URLs point at localhost (DEFAULT; local-first)
#   WEVIBE_ENV=production    → public hosts (NOT deployed yet — placeholders)
# Precedence: an explicit per-URL var below > the WEVIBE_ENV base default.
# This file is loaded from the package root regardless of the process CWD.
WEVIBE_ENV=local

# ── Per-URL overrides (optional; each wins over the WEVIBE_ENV base) ────────
# Hub API (browser/plugin → hub)
# WEVIBE_HUB_URL=http://localhost:4440
# Chain REST trust anchor used for org endpoint resolution
# WEVIBE_CHAIN_REST_URL=http://localhost:1317
# Dashboard base URL for the plugin→dashboard pairing/adopt deep link
# (local default http://localhost:3001 — matches `next dev -p 3001`)
# WEVIBE_DASHBOARD_URL=http://localhost:3001
# MCP local HTTP sidecar port (must match the dashboard's WEVIBE_MCP_HTTP_URL)
# WEVIBE_MCP_HTTP_PORT=4450

# ── Production URLs — fill real values at VPS deploy, then set ───────────────
# WEVIBE_ENV=production and republish. This is the ONE place to seat the real
# public hosts. Until filled, WEVIBE_ENV=production resolves hub/chain to
# unresolvable *.PLACEHOLDER.invalid tokens, so nothing goes live by accident.
# These per-URL vars take PRECEDENCE over the WEVIBE_ENV base.
#   Two-step VPS flip: (1) fill the real URLs below  (2) set WEVIBE_ENV=production → republish
# WEVIBE_DASHBOARD_URL=https://app.wevibe.network                 # canonical dashboard host
# WEVIBE_HUB_URL=https://hub.PLACEHOLDER.invalid                  # TODO(VPS): real hub host
# WEVIBE_CHAIN_REST_URL=https://chain-rest.PLACEHOLDER.invalid    # TODO(VPS): real chain REST host

# ── Local-always services (not switched by WEVIBE_ENV) ─────────────────────
# Ollama (LLM + embeddings)
WEVIBE_OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
WEVIBE_HTTP_HOST=127.0.0.1
# Models
WEVIBE_EMBEDDING_MODEL=nomic-embed-text
